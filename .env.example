# Copiá este archivo a .env y completá con los valores de:
# Firebase Console → Project settings → Your apps → SDK setup and configuration

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: email de referencia del admin (solo documentación / UI).
# El rol "admin" NO se asigna desde el cliente: seteá `role: "admin"` en el
# documento users/{uid} desde Firebase Console o el Admin SDK.
VITE_ADMIN_EMAIL=
